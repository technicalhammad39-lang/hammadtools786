rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdminByEmail() {
      return isAuthenticated() &&
        request.auth.token.email == "technicalhammad39@gmail.com";
    }

    function roleFromDoc() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
        : null;
    }

    function isAdminByDoc() {
      return isAuthenticated() &&
        (roleFromDoc() == "admin" || roleFromDoc() == "Admin");
    }

    function isManagerByDoc() {
      return isAuthenticated() &&
        (roleFromDoc() == "manager" ||
         roleFromDoc() == "Manager" ||
         roleFromDoc() == "staff" ||
         roleFromDoc() == "Staff");
    }

    function isAdmin() {
      return isAdminByEmail() || isAdminByDoc();
    }

    function isStaff() {
      return isAdmin() || isManagerByDoc();
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidRating(value) {
      return (value is int || value is float) && value >= 1 && value <= 5;
    }

    function normalizedOrderStatus(data) {
      return (data.status == "approved" || data.status == "rejected")
        ? data.status
        : "pending";
    }

    function isOrderFinalized(data) {
      return normalizedOrderStatus(data) == "approved" || normalizedOrderStatus(data) == "rejected";
    }

    function canUpdateOrderStatus() {
      return !isOrderFinalized(resource.data) ||
        normalizedOrderStatus(request.resource.data) == normalizedOrderStatus(resource.data);
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isStaff();
      allow create: if isOwner(userId) &&
        hasOnlyAllowedFields(["uid", "email", "displayName", "photoURL", "role", "createdAt", "updatedAt"]) &&
        (request.resource.data.role == "user" || isAdmin());
      allow update: if isAdmin() || (isOwner(userId) && request.resource.data.role == resource.data.role);
      allow delete: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /site_pages/{pageId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /services/{serviceId} {
      allow read: if true;
      allow write: if isStaff();
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isStaff();
    }

    match /payment_methods/{paymentMethodId} {
      allow read: if (resource.data.active == true) || isAdmin();
      allow write: if isAdmin();
    }

    match /agency_services/{serviceId} {
      allow read: if true;
      allow write: if isStaff();
    }

    match /blogPosts/{postId} {
      allow read: if resource.data.published == true || isStaff();
      allow write: if isStaff();
    }

    match /coupons/{couponId} {
      allow read: if resource.data.active == true || isStaff();
      allow write: if isStaff();
    }

    match /service_reviews/{reviewId} {
      allow read: if true;
      allow create: if
        hasOnlyAllowedFields([
          "serviceSlug",
          "serviceId",
          "userName",
          "userEmailMasked",
          "userPhotoURL",
          "text",
          "rating",
          "createdAt"
        ]) &&
        request.resource.data.serviceSlug is string &&
        (!("serviceId" in request.resource.data) || request.resource.data.serviceId is string) &&
        request.resource.data.userName is string &&
        (!("userEmailMasked" in request.resource.data) || request.resource.data.userEmailMasked is string || request.resource.data.userEmailMasked == null) &&
        (!("userPhotoURL" in request.resource.data) || request.resource.data.userPhotoURL is string || request.resource.data.userPhotoURL == null) &&
        request.resource.data.text is string &&
        isValidRating(request.resource.data.rating);
      allow update, delete: if isStaff();
    }

    match /newsletter_subscribers/{subscriberId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /service_activations/{activationId} {
      allow read: if isStaff() || (isAuthenticated() && request.auth.uid == resource.data.userId);
      allow create, update, delete: if isStaff();
    }

    match /orders/{orderId} {
      allow read: if isStaff() || (
        isAuthenticated() && (
          request.auth.uid == resource.data.userId ||
          request.auth.uid == resource.data.user_id
        )
      );
      allow create: if isAuthenticated() && (
        request.resource.data.userId == request.auth.uid ||
        request.resource.data.user_id == request.auth.uid
      ) &&
      request.resource.data.orderId is string &&
      request.resource.data.status == "pending" &&
      (request.resource.data.totalAmount is int || request.resource.data.totalAmount is float) &&
      (!("note" in request.resource.data) || request.resource.data.note is string);
      allow update: if isStaff() && canUpdateOrderStatus();
      allow delete: if isStaff();

      match /messages/{messageId} {
        allow read: if isStaff() || (
          isAuthenticated() &&
          exists(/databases/$(database)/documents/orders/$(orderId)) &&
          (
            request.auth.uid == get(/databases/$(database)/documents/orders/$(orderId)).data.userId ||
            request.auth.uid == get(/databases/$(database)/documents/orders/$(orderId)).data.user_id
          )
        );
        allow create: if isStaff();
        allow update, delete: if false;
      }
    }

    match /entitlements/{entitlementId} {
      allow read: if isStaff() || (isAuthenticated() && request.auth.uid == resource.data.userId);
      allow create, update, delete: if isStaff();
    }

    match /notifications/{notificationId} {
      allow read: if isStaff() || (isAuthenticated() && request.auth.uid == resource.data.recipientId);
      allow create, delete: if isStaff();
      allow update: if isStaff() || (
        isAuthenticated() &&
        request.auth.uid == resource.data.recipientId &&
        request.resource.data.recipientId == resource.data.recipientId &&
        request.resource.data.read is bool
      );
    }

    match /push_tokens/{tokenId} {
      allow read: if isAdmin() || (isAuthenticated() && request.auth.uid == resource.data.userId);
      allow create, update: if isAuthenticated() && request.auth.uid == request.resource.data.userId;
      allow delete: if isAdmin() || (isAuthenticated() && request.auth.uid == resource.data.userId);
    }

    match /notification_dispatches/{dispatchId} {
      allow read, write: if isStaff();
    }

    match /giveaways/{giveawayId} {
      allow read: if true;
      allow write: if isStaff();

      match /comments/{commentId} {
        allow read: if true;
        allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
        allow update, delete: if isStaff();
      }

      match /entries/{entryId} {
        allow read: if isStaff() || (isAuthenticated() && request.auth.uid == resource.data.userId);
        allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
        allow update, delete: if isStaff();
      }
    }

    match /user_entries/{entryId} {
      allow read: if isStaff() || (isAuthenticated() && request.auth.uid == resource.data.userId);
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isStaff();
    }
  }
}

